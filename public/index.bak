<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Assessment Platform</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body{font-family:system-ui;background:#f5f7fb;margin:0}
    header{background:#0d6efd;color:#fff;padding:2rem;text-align:center}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;padding:2rem;max-width:1100px;margin:auto}
    .card{background:#fff;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,.08);padding:1.5rem;text-align:center;cursor:pointer;transition:transform .2s}
    .card:hover{transform:translateY(-4px)}
    .card i{font-size:2.2rem;margin-bottom:.7rem}
  </style>
</head>
<body>
<header><h1>Instant Maturity Assessments</h1></header>
<div class="grid" id="catalog"></div>
<script>
fetch('/api/config').then(r=>r.json()).then(list=>{
  document.getElementById('catalog').innerHTML = list.map(q=>`
    <div class="card" onclick="location.href='assess.html?q=${q.id}'">
      <i class="fa ${q.icon}" style="color:${q.color}"></i>
      <h3>${q.title}</h3>
      <p>${q.blurb}</p>
    </div>`).join('');
});
</script>
</body>
</html>
